#!/bin/bash
# Diff file picker for tmux — extracts file paths from pane content,
# lets you pick via fzf, copies to clipboard (no trailing newline).
pane_file="${1:?Usage: tmux-diff-file-pick <pane-content-file>}"

# Top-level project dirs recognized by the path-shape extractor.
# Lookbehind in the perl regex below rejects matches preceded by '/' or
# alphanumeric, so absolute paths like /var/log/foo.log don't false-match.
PROJECT_DIRS='app|bin|config|db|docs|lib|log|node_modules|public|spec|storage|swagger|test|tmp|vendor|script|frontend|src'

# Two extraction sources, combined and deduped:
#   1. Prefix-style lines (diff/status formats):
#        Δ path/to/file
#        diff --git a/path b/path
#        --- a/path  /  +++ b/path
#        added: path  /  deleted: path  /  renamed: old -> new
#        modified:   path  /  new file:   path  /  deleted:    path  /  renamed:    old -> new
#        untracked (tab-indented bare path under "Untracked files:")
#      Catches top-level files (Gemfile, tmux.conf), extensionless files
#      (bin/rails), and bare directories (userscripts/) that the path-shape
#      extractor would miss.
#   2. Path-shape tokens anywhere on a line: PROJECT_DIRS prefix, slash, body,
#      .ext, optional :line. Catches paths in stack traces, ripgrep output,
#      error messages, comments, etc.
plain=$(sed 's/\x1b\[[0-9;]*m//g' "$pane_file")
file=$({
  printf '%s\n' "$plain" | sed -n \
    -e 's/^Δ \(.*\)/\1/p' \
    -e 's/^diff --git a\/.* b\/\(.*\)/\1/p' \
    -e 's/^+++ b\/\(.*\)/\1/p' \
    -e 's/^--- a\/\(.*\)/\1/p' \
    -e 's/^added: \(.*\)/\1/p' \
    -e 's/^deleted: \(.*\)/\1/p' \
    -e 's/^renamed: .* -> \(.*\)/\1/p' \
    -e 's/^[[:space:]]*modified: *\(.*\)/\1/p' \
    -e 's/^[[:space:]]*new file: *\(.*\)/\1/p' \
    -e 's/^[[:space:]]*deleted: *\(.*\)/\1/p' \
    -e 's/^[[:space:]]*renamed: *.* -> \(.*\)/\1/p' \
    -e '/^\t[^:]*$/ s/^\t\(.*\)$/\1/p'
  printf '%s\n' "$plain" | perl -nle 'while (m{(?<![/A-Za-z0-9])('"$PROJECT_DIRS"')/[A-Za-z0-9_./-]+\.[A-Za-z0-9]+(:[0-9]+)?}g) { print $& }'
} | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
  | awk '!seen[$0]++' \
  | fzf --no-sort --multi --layout=reverse --prompt="Copy file: " \
        --jump-labels='ASDFGHJKLQWERTYUIOPZXCVBNM' \
        --bind='ctrl-f:jump' \
        --bind='jump:accept' \
        --bind='jump-cancel:unbind(load)' \
        --bind='ctrl-a:select-all+accept' \
        --header='Enter=copy, Ctrl-A=copy all, Ctrl-F=jump labels')

if [ -n "$file" ]; then
  result=$(echo "$file" | tr '\n' ' ' | sed 's/ $//')
  printf '%s' "$result" | pbcopy
  tmux display-message "Copied: $result"
fi
