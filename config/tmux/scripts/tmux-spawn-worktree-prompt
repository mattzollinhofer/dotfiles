#!/bin/bash
# Reads branch + prompt input from a tmux popup, then dispatches the worker
# script in the background so the popup closes immediately.
#
# Args: [mode]   mode is `chat` (default) or `plan`.
#
# Bound from tmux.conf via:
#   bind C-w display-popup -E ... "...tmux-spawn-worktree-prompt"        # chat
#   bind p   display-popup -E ... "...tmux-spawn-worktree-prompt plan"   # plan
set -u

mode="${1:-chat}"

if [ "$mode" = "plan" ]; then
  printf '[plan mode] branch (optional, zz/ added if missing): '
else
  printf 'branch (optional, zz/ added if missing): '
fi
IFS= read -r branch || branch=""

if [ "$mode" = "plan" ]; then
  printf 'plan topic / prompt: '
else
  printf 'prompt (optional): '
fi
IFS= read -r prompt || prompt=""

if [ -z "${branch:-}" ] && [ -z "${prompt:-}" ]; then
  printf '\nnothing to spawn\n'
  sleep 0.4
  exit 0
fi

if [ "$mode" = "plan" ] && [ -z "${prompt:-}" ]; then
  printf '\nplan mode requires a prompt\n'
  sleep 0.6
  exit 0
fi

nohup "$HOME/.config/tmux/scripts/tmux-spawn-worktree" \
  --mode "$mode" "${branch:-}" "${prompt:-}" "$PWD" \
  >>/tmp/tmux-spawn-worktree.log 2>&1 &
disown || true

printf '\nspawning...\n'
sleep 0.3
