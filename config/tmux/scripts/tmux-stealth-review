#!/usr/bin/env bash
# tmux-stealth-review
#
# Quietly look at a PR before deciding whether to sign up to review it. Opens a
# NEW tmux window named "stealth-review", then in it:
#
#   1. `w pr:<n>`               worktrunk create-or-switch for the PR's worktree
#   2. `prs r --stealth <url>`  show the PR's comments + open the prr review file
#
# Worktrunk owns the worktree on purpose. `wt switch` (which `w pr:<n>` calls) is
# create-or-switch in one command, so there is nothing to pre-check, and it runs
# the welcomehome pre/post-start hooks -- the worktree comes up as a fully
# configured, runnable test environment (ports, db, direnv), not a bare checkout.
# It also names the worktree after the PR's OWN branch, so there is no fixed-name
# "stealth-review" worktree fighting worktrunk's branch==worktree convention, and
# the branch prs checks out matches the worktree worktrunk made. `wt switch pr:<n>`
# is a plain checkout -- no "starting review" comment, no reviewer assignment --
# so the stealth property holds even before prs runs.
#
# prs needs the full PR URL (not a bare number); we always hand it the URL. It is
# layered on top only for its review view: the PR comments and the prr review
# file. With --stealth it posts nothing and touches no reviewer assignments.
#
# Usage: tmux-stealth-review <pr-url>     (e.g. from the PR popup, ctrl-s)
#        tmux-stealth-review <pr-number>  (assumes the welcomehome repo)
#
# Commands are typed into an interactive shell (send-keys) because `w`/`wt` are
# zsh functions (worktrunk's cd shim), not binaries.

set -euo pipefail

PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
export PATH

arg="${1:-}"
if [ -z "$arg" ]; then
  tmux display-message "tmux-stealth-review: need a PR url or number"
  exit 1
fi

# Resolve repo + number from either a full PR url or a bare number (welcomehome).
if [ "${arg#https://github.com/}" != "$arg" ]; then
  IFS=/ read -r org repo _kind number <<<"${arg#https://github.com/}"
  pr_url="$arg"
else
  org="welcomehome-software"
  repo="welcomehome"
  number="$arg"
  pr_url="https://github.com/$org/$repo/pull/$number"
fi

case "$number" in
  *[!0-9]* | "")
    tmux display-message "tmux-stealth-review: could not parse PR number from: $arg"
    exit 1
    ;;
esac

repo_dir="$HOME/code/$repo"
if [ ! -d "$repo_dir" ]; then
  tmux display-message "tmux-stealth-review: no local clone at $repo_dir"
  exit 1
fi

win_id="$(tmux new-window -P -F '#{window_id}' -n stealth-review -c "$repo_dir")"

# Give the new shell a moment to source its rc files (worktrunk's `w`/`wt` shims
# load from the zsh profile) before typing.
sleep 0.4
tmux send-keys -t "$win_id" -l "w pr:$number && prs r --stealth $pr_url"
tmux send-keys -t "$win_id" Enter
