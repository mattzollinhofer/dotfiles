#!/usr/bin/env bash
# tmux-pr-popup
#
# fzf list of open PRs awaiting my review -- the `prs me` queue -- for use inside
# a tmux display-popup. Phase 2 of the tmux-status roadmap.
#
#   enter   open the highlighted PR in the browser
#   ctrl-y  copy the PR URL to the clipboard, then close
#   esc     close
#
# The source query matches playbook `prs me` and tmux-status-github-poll, so this
# list and the status-bar count can never disagree.
#
# Columns: #id, title, relative-age. Repo/org and labels are intentionally
# omitted -- every review PR is in welcomehome, so the repo is noise. The PR URL
# rides along as a hidden trailing field (the key bindings read it as {2}); it is
# pasted on AFTER alignment so `column` never sees it.

set -euo pipefail

# display-popup may hand us a minimal PATH; brew binaries (gh, fzf) live outside it.
PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
export PATH

GITHUB_ORG="welcomehome-software"

json="$(gh search prs --state=open --owner="$GITHUB_ORG" --review-requested=@me \
  --json number,title,updatedAt,url)"

if [ "$(printf '%s' "$json" | jq 'length')" -eq 0 ]; then
  printf '\n  No PRs awaiting your review.\n\n  Press any key to close. '
  read -rsn1 _
  exit 0
fi

# Aligned display columns (no URL), then the URLs in the same order, then paste
# them back together with a single tab so fzf can show column 1 and act on {2}.
display="$(printf '%s' "$json" | jq -r '
  def ago: (now - fromdateiso8601) as $s
    | if   $s < 3600  then "\(($s / 60)    | floor)m ago"
      elif $s < 86400 then "\(($s / 3600)  | floor)h ago"
      else                 "\(($s / 86400) | floor)d ago"
      end;
  .[] | "#\(.number)\t\(.title)\t\(.updatedAt | ago)"
' | column -t -s "$(printf '\t')")"

urls="$(printf '%s' "$json" | jq -r '.[].url')"

paste -d "$(printf '\t')" <(printf '%s\n' "$display") <(printf '%s\n' "$urls") | fzf \
  --delimiter="$(printf '\t')" \
  --with-nth=1 \
  --reverse \
  --no-multi \
  --prompt='review > ' \
  --header='enter: open in browser    ctrl-y: copy url    esc: close' \
  --bind='enter:become(open {2})' \
  --bind='ctrl-y:execute-silent(printf %s {2} | pbcopy)+abort'
