#!/bin/sh
# open-in-nvim — open file(s) in nvim in a fresh iTerm window. No tmux.
#
# This is the launcher behind the "Open in nvim" Finder wrapper app, which is set as
# the default handler for markdown (see macos/build-finder-opener). Multiple files open
# as tabs in one window. Quitting nvim ends the window's session.
#
# Can also be run straight from a shell: open-in-nvim notes.md todo.md

set -eu

# AppleScript's `do shell script` runs with a minimal PATH; make our tools reachable.
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# iTerm execs its profile command directly, without our shell PATH, so use nvim's
# absolute path or it fails with "nvim: No such file or directory".
nvim_bin=$(command -v nvim)

[ "$#" -gt 0 ] || exit 0

# Build the command iTerm will run: nvim -p 'file1' 'file2' ... (each file a tab).
# Single-quote each path so spaces survive (paths with literal quotes aren't handled,
# which markdown files essentially never have).
cmd="$nvim_bin -p"
for file in "$@"; do
  cmd="$cmd '$file'"
done

osascript <<APPLESCRIPT
tell application "iTerm"
  activate
  create window with default profile command "$cmd"
end tell
APPLESCRIPT
